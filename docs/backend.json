
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Extended user profile with role and approval status.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "PUNCH_LIST", "INVENTORY", "WORKER"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffMember": {
      "title": "StaffMember",
      "type": "object",
      "description": "Represents an individual staff member or employee within Generals Plumbing.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "officialRole": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "hireDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "officialRole", "address", "email"]
    },
    "MaterialRequest": {
      "title": "MaterialRequest",
      "type": "object",
      "description": "A request for materials submitted by a worker.",
      "properties": {
        "id": { "type": "string" },
        "workerUid": { "type": "string" },
        "workerName": { "type": "string" },
        "category": { "type": "string", "enum": ["Rough", "Underslab", "Final"] },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "deliveryAddress": { "type": "string" },
        "requestTime": { "type": "string", "format": "date-time" },
        "deliveryTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "delivered"] }
      },
      "required": ["workerUid", "category", "itemId", "quantity", "deliveryAddress", "requestTime", "status"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "type": "object",
      "description": "Global application configurations.",
      "properties": {
        "signupDisabled": { "type": "boolean" },
        "chatId": { "type": "string", "description": "Telegram Chat ID for notifications." }
      }
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "type": "object",
      "description": "Plumbing part or supply in inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "currentStock": { "type": "number" },
        "reorderThreshold": { "type": "number" }
      },
      "required": ["id", "name", "currentStock"]
    },
    "PunchList": {
      "title": "PunchList",
      "type": "object",
      "description": "A task or deficiency that needs to be addressed at a job site.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "completed"] },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile with role."
    },
    "/materialRequests/{requestId}": {
      "schema": "#/backend/entities/MaterialRequest",
      "description": "Worker material requests."
    },
    "/appSettings/{settingId}": {
      "schema": "#/backend/entities/AppSetting",
      "description": "Settings."
    },
    "/staffMembers/{staffMemberId}": {
      "schema": "#/backend/entities/StaffMember",
      "description": "Staff registry."
    },
    "/inventoryItems/{inventoryItemId}": {
      "schema": "#/backend/entities/InventoryItem",
      "description": "Material catalog."
    },
    "/punchLists/{punchListId}": {
      "schema": "#/backend/entities/PunchList",
      "description": "Job site deficiency tracking."
    }
  }
}
