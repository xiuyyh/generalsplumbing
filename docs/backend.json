{
  "entities": {
    "StaffMember": {
      "title": "StaffMember",
      "type": "object",
      "description": "Represents an individual staff member or employee within Generals Plumbing.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "officialRole": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "hireDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "officialRole", "address", "email"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "type": "object",
      "description": "Global application configurations.",
      "properties": {
        "signupDisabled": { "type": "boolean" },
        "chatId": { "type": "string", "description": "Telegram Chat ID for notifications." }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "type": "object",
      "description": "Records clock-in/out times for staff shifts.",
      "properties": {
        "id": { "type": "string" },
        "staffMemberId": { "type": "string" },
        "clockInTime": { "type": "string", "format": "date-time" },
        "clockOutTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "staffMemberId", "clockInTime"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "type": "object",
      "description": "Plumbing part or supply in inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "currentStock": { "type": "number" },
        "reorderThreshold": { "type": "number" },
        "unitOfMeasure": { "type": "string" },
        "pricePerUnit": { "type": "number" }
      },
      "required": ["id", "name", "sku", "currentStock"]
    },
    "InventoryDispatch": {
      "title": "InventoryDispatch",
      "type": "object",
      "description": "Records the dispatch or usage of inventory items.",
      "properties": {
        "id": { "type": "string" },
        "inventoryItemId": { "type": "string" },
        "quantity": { "type": "number" },
        "dispatchDateTime": { "type": "string", "format": "date-time" },
        "assignedToStaffMemberId": { "type": "string" },
        "purpose": { "type": "string" },
        "deliveryAddress": { "type": "string" }
      },
      "required": ["id", "inventoryItemId", "quantity", "dispatchDateTime", "assignedToStaffMemberId"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/appSettings/{settingId}": {
      "schema": "#/backend/entities/AppSetting",
      "description": "Global application settings (auth toggle, telegram config)."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile mapping."
    },
    "/roles_admin/{userId}": {
      "schema": "#/backend/entities/AdminRole",
      "description": "Admin role sentinel."
    },
    "/staffMembers/{staffMemberId}": {
      "schema": "#/backend/entities/StaffMember",
      "description": "Staff registry."
    },
    "/timeEntries/{timeEntryId}": {
      "schema": "#/backend/entities/TimeEntry",
      "description": "Attendance logs."
    },
    "/inventoryItems/{inventoryItemId}": {
      "schema": "#/backend/entities/InventoryItem",
      "description": "Material catalog."
    },
    "/inventoryDispatches/{inventoryDispatchId}": {
      "schema": "#/backend/entities/InventoryDispatch",
      "description": "Usage history."
    }
  }
}
