
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Extended user profile with role and approval status.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "PUNCH_LIST", "INVENTORY", "WORKER"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AttendanceToken": {
      "title": "AttendanceToken",
      "type": "object",
      "description": "A secure token used for QR code clock-in/out verification.",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "string", "description": "Unique random token value." },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminNote": { "type": "string", "description": "A message or notice from the admin to staff." }
      }
    },
    "MaterialRequest": {
      "title": "MaterialRequest",
      "type": "object",
      "description": "A request for materials submitted by a worker.",
      "properties": {
        "id": { "type": "string" },
        "workerUid": { "type": "string" },
        "workerName": { "type": "string" },
        "category": { "type": "string", "enum": ["Rough", "Underslab", "Final", "Extra", "Warranty"] },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number" },
        "deliveryAddress": { "type": "string" },
        "requestTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "dispatched", "rejected"] },
        "rejectionNote": { "type": "string" }
      }
    },
    "InventoryDispatch": {
      "title": "InventoryDispatch",
      "type": "object",
      "description": "A record of material leaving inventory for a job site.",
      "properties": {
        "id": { "type": "string" },
        "inventoryItemId": { "type": "string" },
        "quantity": { "type": "number" },
        "dispatchDateTime": { "type": "string", "format": "date-time" },
        "dispatchedByStaffMemberId": { "type": "string" },
        "assignedToStaffMemberId": { "type": "string" },
        "purpose": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "type": "object",
      "description": "A technician's clock-in/out record mapped to their User ID.",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "clockInTime": { "type": "string", "format": "date-time" },
        "clockOutTime": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "type": "object",
      "description": "Plumbing part or supply in inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "currentStock": { "type": "number" },
        "reorderThreshold": { "type": "number" }
      }
    },
    "PunchList": {
      "title": "PunchList",
      "type": "object",
      "description": "A task or deficiency that needs to be addressed at a job site.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "completed"] },
        "photoUrls": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profile with role."
    },
    "/attendanceTokens/{tokenId}": {
      "schema": "#/backend/entities/AttendanceToken",
      "description": "Active QR tokens for clocking."
    },
    "/materialRequests/{requestId}": {
      "schema": "#/backend/entities/MaterialRequest",
      "description": "Worker material requests."
    },
    "/inventoryDispatches/{dispatchId}": {
      "schema": "#/backend/entities/InventoryDispatch",
      "description": "Authorized material outflow logs."
    },
    "/timeEntries/{entryId}": {
      "schema": "#/backend/entities/TimeEntry",
      "description": "Clock in/out records."
    },
    "/inventoryItems/{inventoryItemId}": {
      "schema": "#/backend/entities/InventoryItem",
      "description": "Material catalog."
    },
    "/punchLists/{punchListId}": {
      "schema": "#/backend/entities/PunchList",
      "description": "Job site deficiency tracking."
    }
  }
}
