
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core authorization functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to check if a user document exists and get its data safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Check if user profile exists and is approved or is an admin
    function isApproved() {
      return isSignedIn() && 
             userExists() &&
             (getUserData().status == 'approved' || getUserData().role == 'ADMIN');
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() && 
             getUserData().role == 'ADMIN';
    }

    // User Profile Rules
    match /users/{userId} {
      // Allow a user to get their own profile even if pending
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Admins can manage all profiles
      allow read, write: if isAdmin();
      // Allow initial profile creation during signup
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Attendance & QR Rules
    match /attendanceTokens/{tokenId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /timeEntries/{entryId} {
      // Workers can see their own logs, Admins see all
      allow read: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Material Request & Inventory Rules
    match /materialRequests/{requestId} {
      // Approved users can create/read their own requests
      allow create: if isApproved();
      allow read: if isApproved() && (request.auth.uid == resource.data.workerUid || isAdmin() || getUserData().role == 'INVENTORY');
      // Management roles can update status
      allow update: if isApproved() && (getUserData().role == 'INVENTORY' || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      // All signed-in users can view the catalog to build requests
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isApproved() && getUserData().role == 'INVENTORY');
    }

    match /inventoryDispatches/{dispatchId} {
      allow read: if isApproved();
      allow write: if isAdmin() || (isApproved() && getUserData().role == 'INVENTORY');
    }

    match /bundles/{bundleId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // Punch List Rules
    match /punchLists/{punchId} {
      allow read: if isApproved();
      allow write: if isApproved() && (getUserData().role == 'PUNCH_LIST' || isAdmin());
    }

    // Global App Settings (Public for Login Screen and Bootstrapping)
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
