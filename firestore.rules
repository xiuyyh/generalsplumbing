
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isApproved() {
      return isSignedIn() && (getUserData().status == 'approved' || getUserData().role == 'ADMIN');
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /attendanceTokens/{tokenId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /timeEntries/{entryId} {
      allow read: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isApproved() && request.auth.uid == request.resource.data.userId;
      allow update: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /materialRequests/{requestId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved() && (getUserData().role == 'INVENTORY' || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      allow read: if isApproved();
      allow write: if isAdmin() || (isApproved() && getUserData().role == 'INVENTORY');
    }

    match /punchLists/{punchId} {
      allow read: if isApproved() && (getUserData().role == 'PUNCH_LIST' || isAdmin());
      allow write: if isApproved() && (getUserData().role == 'PUNCH_LIST' || isAdmin());
    }

    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
