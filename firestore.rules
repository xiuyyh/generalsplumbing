
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core authorization functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to get user document data safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user profile exists and is approved or is an admin
    // Added exists() check to prevent evaluation errors when profile is missing
    function isApproved() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (getUserData().status == 'approved' || getUserData().role == 'ADMIN');
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'ADMIN';
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Attendance & QR Rules
    match /attendanceTokens/{tokenId} {
      allow read: if isSignedIn(); // Allow reading tokens for any signed in user to check status
      allow write: if isAdmin();
    }

    match /timeEntries/{entryId} {
      allow read: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isApproved() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Material Request & Inventory Rules
    match /materialRequests/{requestId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved() && (getUserData().role == 'INVENTORY' || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      // Relaxed to isSignedIn so workers/pending users can see parts for requests
      // while they wait for full approval, preventing dashboard crashes.
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isApproved() && getUserData().role == 'INVENTORY');
    }

    match /inventoryDispatches/{dispatchId} {
      allow read: if isApproved();
      allow write: if isAdmin() || (isApproved() && getUserData().role == 'INVENTORY');
    }

    match /bundles/{bundleId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // Punch List Rules
    match /punchLists/{punchId} {
      allow read: if isApproved();
      allow write: if isApproved() && (getUserData().role == 'PUNCH_LIST' || isAdmin());
    }

    // Global App Settings (Public for Login Screen and Bootstrapping)
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
