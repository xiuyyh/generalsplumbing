rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy:
     * This ruleset implements a dual-layered authorization model: Role-Based Access Control (RBAC) 
     * via an admin sentinel collection and Ownership-Based Access Control for staff-related operations.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getLinkedStaffId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.staffMemberId;
    }

    // --- Collection Rules ---

    /** Settings are readable by all (to check signup status) but writable only by admins. */
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.staffMemberId == resource.data.staffMemberId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId); // Convenience: First user can become admin
      allow update, delete: if isAdmin();
    }

    match /staffMembers/{staffMemberId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    match /timeEntries/{timeEntryId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.staffMemberId == getLinkedStaffId());
      allow list: if isAdmin() || (isSignedIn()); 
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /inventoryItems/{inventoryItemId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    match /inventoryDispatches/{inventoryDispatchId} {
      allow get: if isAdmin() || (isSignedIn() && (resource.data.dispatchedByStaffMemberId == getLinkedStaffId() || resource.data.assignedToStaffMemberId == getLinkedStaffId()));
      allow list: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.dispatchedByStaffMemberId == getLinkedStaffId());
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /punchLists/{punchListId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
