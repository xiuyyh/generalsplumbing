
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isApproved() {
      return isSignedIn() && (getUserData().status == 'approved' || getUserData().role == 'ADMIN');
    }
    
    function hasRole(role) {
      return isApproved() && getUserData().role == role;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'ADMIN';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /materialRequests/{requestId} {
      allow read: if isApproved();
      allow create: if isApproved() && (hasRole('WORKER') || isAdmin());
      allow update: if isApproved() && (hasRole('INVENTORY') || isAdmin());
      allow delete: if isAdmin();
    }

    match /bundles/{bundleId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      allow read: if isApproved();
      allow write: if isAdmin() || hasRole('INVENTORY');
    }

    match /punchLists/{punchId} {
      allow read: if isApproved() && (hasRole('PUNCH_LIST') || isAdmin());
      allow write: if isAdmin() || hasRole('PUNCH_LIST');
    }

    match /staffMembers/{staffId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{uid} {
      allow list: if isSignedIn() && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
  }
}
