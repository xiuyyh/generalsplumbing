
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * Storage rules for Generals Plumbing.
     * Allows authenticated users (admins) to upload site documentation.
     */
    match /punchLists/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
